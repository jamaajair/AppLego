package org.spftech.backend.ruleunit

unit DossierStateValidationUnit

import org.spftech.backend.entity.Dossier

// Group 1: dossier must be in New state (codeValue "N")
rule "Validate dossier state"
when
    /dossiers[ state.code.codeValue != "N" ]
then
    validationMessages.add("Validation Error: Dossier must be in 'New' state to add participants");
end
